generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionTier {
  PRELUDE
  SONATA
  SYMPHONY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum Language {
  EN
  EL
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              Role               @default(STUDENT)
  preferredLanguage Language           @default(EN)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Stripe
  stripeCustomerId  String?            @unique

  // Relations
  subscription      Subscription?
  accounts          Account[]
  sessions          Session[]
  teacherProfile    TeacherProfile?
  enrollments       Enrollment[]
  bookings          Booking[]          @relation("StudentBookings")
  taughtBookings    Booking[]          @relation("TeacherBookings")
  practiceLog       PracticeLog[]
  aiFeedbacks       AIFeedback[]
  progress          Progress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?  @db.Text
  bioEl       String?  @db.Text
  instruments String[]
  experience  Int?     // years
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  availability Availability[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 SubscriptionTier   @default(PRELUDE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lesson {
  id           String       @id @default(cuid())
  teacherId    String
  title        String
  titleEl      String?
  description  String?      @db.Text
  descriptionEl String?     @db.Text
  videoUrl     String?
  thumbnailUrl String?
  duration     Int?         // minutes
  instrument   String?
  level        String?      // beginner, intermediate, advanced
  tier         SubscriptionTier @default(PRELUDE)
  status       LessonStatus @default(DRAFT)
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  teacher      TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  progress     Progress[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  watched     Boolean  @default(false)
  watchedAt   DateTime?
  watchTime   Int      @default(0) // seconds
  completed   Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Availability {
  id        String   @id @default(cuid())
  teacherId String
  dayOfWeek Int      // 0=Sunday, 6=Saturday
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)

  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String        @id @default(cuid())
  studentId   String
  teacherId   String
  scheduledAt DateTime
  duration    Int           @default(60) // minutes
  status      BookingStatus @default(PENDING)
  notes       String?       @db.Text
  meetingUrl  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  student     User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User          @relation("TeacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
}

model PracticeLog {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @default(now())
  duration   Int      // minutes
  instrument String
  notes      String?  @db.Text
  mood       Int?     // 1-5
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIFeedback {
  id           String   @id @default(cuid())
  userId       String
  recordingUrl String?
  transcript   String?  @db.Text
  feedback     String   @db.Text
  instrument   String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
